POSTGRES_USER=vail
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vail

RUST_LOG=info
VAIL_BACKEND_IMAGE=ghcr.io/ginbun/vail:latest

# Backend database overrides
VAIL_DB_HOST=postgres
VAIL_DB_PORT=5432
VAIL_DB_USERNAME=vail
VAIL_DB_PASSWORD=change-me
VAIL_DB_DATABASE=vail

# JWT configuration
# Choose one mode:
# 1. HS256: set VAIL_JWT_ALGORITHM=HS256 and provide VAIL_JWT_SECRET only.
# 2. EdDSA: set VAIL_JWT_ALGORITHM=EdDSA and provide both VAIL_JWT_PRIVATE_KEY and VAIL_JWT_PUBLIC_KEY as base64 key strings.
VAIL_JWT_ALGORITHM=EdDSA

# For HS256 only
VAIL_JWT_SECRET=

# For EdDSA only (base64 strings, not PEM)
VAIL_JWT_PRIVATE_KEY=
VAIL_JWT_PUBLIC_KEY=

# Data-at-rest encryption key (must be stable per environment)
VAIL_DATA_ENCRYPTION_KEY=
